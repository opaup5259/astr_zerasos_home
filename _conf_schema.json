{
  "github_user": {
    "type": "string",
    "description": "GitHub 用户名",
    "hint": "如: opaup5259",
    "default": "opaup5259"
  },
  "github_token": {
    "type": "string",
    "description": "GitHub 个人访问令牌 (Token)",
    "hint": "需有 repo 权限",
    "default": ""
  },
  "admin_ids": {
    "type": "list",
    "description": "管理员 ID 列表（QQ号）",
    "hint": "一行一个",
    "default": ["525915186"],
    "items": {
      "type": "string"
    }
  },
  "enabled": {
    "type": "bool",
    "description": "是否启用插件",
    "default": true
  },
  "auto_publish": {
    "type": "object",
    "description": "自动发布配置",
    "hint": "定时自动发布说说到博客",
    "sub": {
      "enabled": {
        "type": "bool",
        "description": "是否启用定时自动发布",
        "default": false
      },
      "cron": {
        "type": "string",
        "description": "定时发布 Cron 表达式（5字段: 分 时 日 月 周）",
        "hint": "默认 30 8 * * * 表示每天早上 8:30",
        "default": "30 8 * * *"
      },
      "llm_prompt": {
        "type": "string",
        "description": "LLM 写说说 Prompt 模板（留空使用默认）",
        "hint": "自定义 AI 生成说说的提示词",
        "default": ""
      }
    }
  }
}
